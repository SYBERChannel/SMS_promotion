# ================================================
# SMS Промо — Настройки окружения
# Скопируйте этот файл в .env и заполните значения
# ================================================

# Порт сервера (по умолчанию 3000)
PORT=3000

# ---------- SMTP ----------

# Хост SMTP-сервера
# Примеры:
#   Яндекс:  smtp.yandex.ru
#   Mail.ru: smtp.mail.ru
#   Gmail:   smtp.gmail.com
#   Своя почта (например, REG.RU): mail.reg.ru
SMTP_HOST=smtp.yandex.ru

# Порт SMTP
#   465 — SSL/TLS (secure=true, рекомендуется)
#   587 — STARTTLS (secure=false)
SMTP_PORT=465

# Использовать SSL/TLS: true (порт 465) или false (порт 587)
SMTP_SECURE=true

# Логин SMTP (обычно совпадает с адресом отправителя)
SMTP_USER=your_email@yandex.ru

# Пароль SMTP
# Для Яндекс: создайте пароль приложения в настройках аккаунта
# Для Gmail: включите 2FA и создайте App Password
SMTP_PASS=your_smtp_password

# Проверять SSL-сертификат сервера (true / false)
# Оставьте true для безопасности; false только для тестов с самоподписанными сертификатами
SMTP_REJECT_UNAUTHORIZED=true

# ---------- Получатель заявок ----------

# Email оператора/менеджера — сюда придут уведомления о новых заявках
OPERATOR_EMAIL=manager@yourcompany.ru
